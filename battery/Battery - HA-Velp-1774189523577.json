          "query": "power = from(bucket: \"homeassistant\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => \r\n      r.entity_id == \"sessy_dn4t_power\" or\r\n      r.entity_id == \"sessy_d9af_power\" or\r\n      r.entity_id == \"sessy_dx3j_power\"\r\n  )\r\n  |> filter(fn: (r) => r._field == \"value\")\r\n  |> aggregateWindow(every: 5m, fn: mean, createEmpty: false)\r\n  |> group(columns: [\"_time\"])\r\n  |> sum()\r\n  |> group()\r\n\r\nprice = from(bucket: \"homeassistant\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r.entity_id == \"frank_energie_prices_current_electricity_price_all_in\")\r\n  |> filter(fn: (r) => r._field == \"value\")\r\n  |> aggregateWindow(every: 5m, fn: last, createEmpty: true)\r\n  |> fill(usePrevious: true)\r\n\r\njoin(tables: {power: power, price: price}, on: [\"_time\"])\r\n  |> map(fn: (r) => ({\r\n      _time: r._time,\r\n      _value: if r._value_power > 0.0\r\n              then r._value_power / 1000.0 * r._value_price * (5.0 / 60.0)\r\n              else 0.0\r\n  }))\r\n  |> cumulativeSum()\r\n  |> map(fn: (r) => ({_time: r._time, _value: r._value, _field: \"Sessy opbrengst (€)\"}))\r\n  |> group(columns: [\"_field\"])",
