        {
          "query": "cop = from(bucket: \"homeassistant\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r.entity_id == \"heatpump_1_quatt_cop\")\r\n  |> filter(fn: (r) => r._field == \"value\")\r\n  |> aggregateWindow(every: 15m, fn: mean, createEmpty: false)\r\n  |> rename(columns: {_value: \"cop\"})\r\n\r\nbuiten = from(bucket: \"homeassistant\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r.entity_id == \"ws2900_v2_01_18_feels_like_temperature\")\r\n  |> filter(fn: (r) => r._field == \"value\")\r\n  |> aggregateWindow(every: 15m, fn: mean, createEmpty: false)\r\n  |> rename(columns: {_value: \"buiten\"})\r\n\r\njoin(tables: {cop: cop, buiten: buiten}, on: [\"_time\"])\r\n  |> map(fn: (r) => ({\r\n      _time: r._time,\r\n      buiten: r.buiten,\r\n      cop: r.cop\r\n  }))",
